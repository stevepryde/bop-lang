{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bop",
  "scopeName": "source.bop",
  "fileTypes": ["bop"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#functionDeclarations" },
    { "include": "#functionCalls" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.bop",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bop",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.bop" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.bop" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.bop",
              "match": "\\\\(?:[nrt\"\\\\]|u\\{[0-9A-Fa-f]+\\})"
            },
            {
              "name": "meta.interpolation.bop",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.bop" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.bop" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.bop",
          "match": "\\b(?:0[xX][0-9A-Fa-f_]+|0[bB][01_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bop",
          "match": "\\b(?:if|else|for|while|loop|match|return|break|continue|try|use|as|in)\\b"
        },
        {
          "name": "storage.type.function.bop",
          "match": "\\bfn\\b"
        },
        {
          "name": "storage.modifier.bop",
          "match": "\\b(?:let|const|pub|ref)\\b"
        },
        {
          "name": "keyword.declaration.bop",
          "match": "\\b(?:struct|enum)\\b"
        },
        {
          "name": "keyword.operator.word.bop",
          "match": "\\b(?:and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.bop",
          "match": "\\b(?:true|false|none)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.bop",
          "match": "\\b(?:int|number|string|bool|array|dict|fn|module|iter|Result|RuntimeError|Iter)\\b"
        },
        {
          "name": "entity.name.type.bop",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functionDeclarations": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "storage.type.function.bop" },
            "2": { "name": "entity.name.function.bop" }
          }
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "meta.function-call.bop",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.bop" }
          }
        }
      ]
    }
  }
}
